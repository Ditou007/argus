{
  "name": "argus",
  "version": "0.1.0",
  "private": true,
  "description": "AI Agent Runtime Governance & Observability Platform",
  "scripts": {
    "dev:ingestion": "pnpm --filter @argus/ingestion dev",
    "dev:api": "pnpm --filter @argus/api dev",
    "dev:dashboard": "pnpm --filter @argus/dashboard dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "k8s:setup": "bash k8s/setup.sh",
    "k8s:teardown": "bash k8s/teardown.sh",
    "k8s:rebuild": "bash k8s/rebuild.sh",
    "k8s:port-forward": "kubectl port-forward svc/argus-api 3001:3001",
    "k8s:agent": "kubectl delete job sample-agent --ignore-not-found && kubectl apply -f k8s/sample-agent-job.yaml",
    "k8s:logs:ingestion": "kubectl logs -f deploy/argus-ingestion",
    "k8s:logs:api": "kubectl logs -f deploy/argus-api",
    "k8s:logs:tetragon": "kubectl logs -f -n kube-system -l app.kubernetes.io/name=tetragon -c tetragon"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@wednesday-sol/keel": "^0.14.0",
    "eslint": "^9",
    "eslint-plugin-sonarjs": "^4",
    "typescript-eslint": "^8.61.0"
  }
}
