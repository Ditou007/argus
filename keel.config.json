{
  "$schema": "node_modules/@wednesday-sol/keel/config/keel.schema.json",
  "profile": "monorepo-pnpm",
  "baseBranches": [
    "main",
    "master",
    "develop"
  ],
  "changesets": {
    "enabled": false,
    "$note": "Argus packages are private apps, not published npm libraries — no changeset ledger."
  },
  "boundary": {
    "allow": [
      "(^|/)pnpm-lock\\.yaml$"
    ],
    "$note": "The lockfile is pnpm-managed; legitimate dependency additions regenerate it. Allowed so normal dep changes don't trip boundary-guard."
  },
  "docs": {
    "docSyncIgnore": [
      ".claude/",
      "docs/specs/"
    ],
    "specSync": {
      "enabled": true,
      "rules": [
        {
          "when": "^packages/api/src/correlation/",
          "requireTouched": "^docs/specs/SPEC_01_correlation_accuracy\\.md$"
        }
      ]
    }
  }
}
