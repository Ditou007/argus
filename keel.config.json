{
  "$schema": "node_modules/@wednesday-sol/keel/config/keel.schema.json",
  "profile": "monorepo-pnpm",
  "baseBranches": [
    "main",
    "master",
    "develop"
  ],
  "docs": {
    "docSyncIgnore": [
      ".claude/"
    ],
    "specSync": {
      "enabled": true,
      "rules": [
        {
          "when": "^packages/api/src/correlation/",
          "requireTouched": "^docs/specs/SPEC_01_correlation_accuracy\\.md$"
        }
      ]
    }
  }
}
