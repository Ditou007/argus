# API
API_PORT=3001

# Tetragon
TETRAGON_EXPORT_PATH=/var/run/tetragon/tetragon.log

# Demo chatbot agent (SPEC_03) — bring-your-own LLM key. Fill in ONE provider.
# docker-compose loads this file automatically for ${VAR} substitution.
# Groq (fast, free tier — https://console.groq.com/keys):
GROQ_API_KEY=
# OR Anthropic (https://console.anthropic.com/):
# ANTHROPIC_API_KEY=
